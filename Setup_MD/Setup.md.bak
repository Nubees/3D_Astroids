## 4. Project Configuration

### 4.1 Project Directory Structure

Inside the project repository (`C:\Projects\3D_Astroids`), create:

```powershell
New-Item -ItemType Directory -Force -Path "C:\Projects\3D_Astroids\.claude\hooks"
New-Item -ItemType Directory -Force -Path "C:\Projects\3D_Astroids\.claude\rules"
New-Item -ItemType Directory -Force -Path "C:\Projects\3D_Astroids\.claude\skills"
New-Item -ItemType Directory -Force -Path "C:\Projects\3D_Astroids\.claude\agents"
New-Item -ItemType Directory -Force -Path "C:\Projects\3D_Astroids\.claude\plans"
New-Item -ItemType Directory -Force -Path "C:\Projects\3D_Astroids\.claude\plugins"
New-Item -ItemType Directory -Force -Path "C:\Projects\3D_Astroids\.remember\logs"
New-Item -ItemType Directory -Force -Path "C:\Projects\3D_Astroids\Knowledge\RAW"
New-Item -ItemType Directory -Force -Path "C:\Projects\3D_Astroids\Knowledge\Wiki"
New-Item -ItemType Directory -Force -Path "C:\Projects\3D_Astroids\Knowledge\Frameworks"
```

- `.remember\logs` — required by the `post-tool-use.cjs` hook.
- `.claude\skills` and `.claude\agents` — project-specific skills and agents (Sections 4.8 and 4.9).
- `.claude\plans` — implementation plans for significant features or refactors.
- `.claude\plugins` — documentation only; plugins are installed globally.
- `Knowledge\RAW` — immutable source material; Austin ingests, never gets edited by Claude.
- `Knowledge\Wiki` — Claude generated synthesis; Claude maintained.
- `Knowledge\Frameworks` — actionable guides; Austin + Claude collaborate.

---

### 4.2 Project Hooks

Hooks are Node.js scripts that run at specific lifecycle points. They communicate via JSON over stdin/stdout.

#### A. Session Start Hook

**Path:** `C:\Projects\3D_Astroids\.claude\hooks\session-start.cjs`

```javascript
#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

const root = path.resolve(__dirname, '..', '..');
const hasNodeModules = fs.existsSync(path.join(root, 'node_modules'));

const messages = [];

messages.push({
  type: 'text',
  content: '3D Astroids project loaded.'
});

if (!hasNodeModules) {
  messages.push({
    type: 'text',
    content: 'node_modules not found. Run the install command for your chosen stack before building.'
  });
}

messages.push({
  type: 'text',
  content: '🛡️ Auto-save active: memory save + recap every 50 minutes.'
});

process.stdout.write(JSON.stringify({
  updatedContext: messages.map(m => m.content).join('\n')
}));
```

**What it does:** Greets the user on every session start, warns if `node_modules` is missing, and reminds about the auto-save obligation.

#### B. Pre-Tool-Use Hook

**Path:** `C:\Projects\3D_Astroids\.claude\hooks\pre-tool-use.cjs`

```javascript
#!/usr/bin/env node

const readline = require('readline');

const rl = readline.createInterface({
  input: process.stdin,
  output: process.stdout,
  terminal: false
});

rl.on('line', (line) => {
  try {
    const event = JSON.parse(line);
    const tool = event?.tool || '';
    const input = event?.input || {};
    const filePath = input.file_path || '';
    const cmd = input.command || '';

    const warnings = [];

    if (tool === 'Bash' || tool === 'PowerShell') {
      const destructivePatterns = [
        /rm\s+-rf/,
        /rmdir\s+\/s/,
        /del\s+\/f/,
        /git\s+push\s+--force/,
        /git\s+reset\s+--hard/,
        /git\s+clean\s+-f/
      ];
      for (const pattern of destructivePatterns) {
        if (pattern.test(cmd)) {
          warnings.push(`Destructive command detected: ${cmd}. Confirm before running.`);
        }
      }

      // Extra guard: deleting memory or Knowledge files via shell
      if (/C:\\\\Users\\\\User101\\\\.claude\\\\projects\\\\C--Projects-3D-Astroids\\\\memory/.test(cmd) ||
          /Knowledge[\\/]RAW/.test(cmd)) {
        warnings.push(`Command references memory or Knowledge/RAW directory. These are protected. Confirm before running.`);
      }
    }

    if (tool === 'Write' || tool === 'Edit') {
      // Secret / env files
      if (filePath.includes('.env')) {
        warnings.push(`Writing to ${filePath}. Never commit secrets.`);
      }

      // Immutable RAW knowledge layer
      if (/Knowledge[\\/]RAW[\\/]/.test(filePath)) {
        warnings.push(`Writing to ${filePath}. Knowledge/RAW/ is immutable. Add a correction note to Knowledge/Wiki/ instead.`);
      }

      // Environment guardrails
      if (filePath.endsWith('.claude/settings.json') || filePath.endsWith('.claude\\settings.json')) {
        warnings.push(`Editing ${filePath}. Changes here can disable hooks or break the status line. Verify hooks and statusLine.command (forward slashes) are preserved.`);
      }

      // Primary rulebook
      if (/[\\/]CLAUDE\.md$/.test(filePath)) {
        warnings.push(`Editing ${filePath}. Ensure the same rule is also updated in memory and/or Knowledge/Frameworks/ if it is a workflow rule.`);
      }

      // Self-setup runbook — maintenance log must be updated
      if (/Setup_MD[\\/]Setup\.md$/.test(filePath)) {
        warnings.push(`Editing ${filePath}. Append a maintenance log entry in Section 9 unless the change is purely formatting.`);
      }

      // Local permissions cache
      if (/settings\.local\.json$/.test(filePath)) {
        warnings.push(`Editing ${filePath}. This file is auto-generated by Claude Code. Manual edits may be overwritten.`);
      }

      // Memory files
      if (/C--Projects-3D-Astroids[\\/]memory[\\/].+\.md$/.test(filePath) ||
          /\.claude[\\/]projects[\\/]C--Projects-3D-Astroids[\\/]memory[\\/].+\.md$/.test(filePath)) {
        warnings.push(`Editing memory file ${filePath}. If deleting, ensure MEMORY.md index is also updated.`);
      }

      // .gitignore changes that could expose secrets
      if (/\.gitignore$/.test(filePath)) {
        warnings.push(`Editing ${filePath}. Do not remove .env, .env.*, node_modules/, dist/, or .claude/settings.local.json protections.`);
      }

      // Status-line command strings with Windows backslashes
      const textToCheck = input.new_string || input.content || '';
      if (/statusLine.*command.*node\s+C:\\\\/.test(textToCheck) ||
          /"command":\s*"node\s+C:\\\\/.test(textToCheck)) {
        warnings.push(`statusLine.command appears to use Windows backslashes. Use forward slashes (C:/Users/...) or the status line will silently fail.`);
      }
    }

    process.stdout.write(JSON.stringify({
      additionalContext: warnings.join('\n') || undefined
    }));
    rl.close();
  } catch (err) {
    process.stdout.write(JSON.stringify({}));
    rl.close();
  }
});
```

**What it does:** Intercepts Bash/PowerShell/Write/Edit tool calls before they execute. Warns about:
- Destructive shell commands (`rm -rf`, `git reset --hard`, etc.)
- `.env` file writes
- Edits to `.claude/settings.json` that could disable hooks or break the status line
- Edits to `CLAUDE.md` without cross-checking memory/frameworks
- Edits to `Setup.md` without updating the maintenance log
- Writes to `Knowledge/RAW/` (immutable layer)
- Deletion of memory files
- `.gitignore` changes that expose secrets
- `statusLine.command` paths using Windows backslashes

#### C. Post-Tool-Use Hook

**Path:** `C:\Projects\3D_Astroids\.claude\hooks\post-tool-use.cjs`

```javascript
#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const readline = require('readline');

const projectRoot = path.resolve(__dirname, '..', '..');
const logDir = path.join(projectRoot, '.remember', 'logs');
const logFile = path.join(logDir, 'hook-errors.log');

try {
  if (!fs.existsSync(logDir)) {
    fs.mkdirSync(logDir, { recursive: true });
  }
  if (!fs.existsSync(logFile)) {
    fs.writeFileSync(logFile, '');
  }
} catch (err) {
  // silently continue to avoid infinite hook error loops
}

const rl = readline.createInterface({
  input: process.stdin,
  output: process.stdout,
  terminal: false
});

rl.on('line', (line) => {
  try {
    const event = JSON.parse(line);
    const tool = event?.tool || '';
    const error = event?.error || event?.result?.error;

    if (error) {
      const timestamp = new Date().toISOString();
      const entry = `[${timestamp}] Tool: ${tool} | Error: ${JSON.stringify(error)}\n`;
      try {
        fs.appendFileSync(logFile, entry);
      } catch (e) {
        // Silent fail to avoid hook loops
      }
    }

    process.stdout.write(JSON.stringify({}));
    rl.close();
  } catch (err) {
    process.stdout.write(JSON.stringify({}));
    rl.close();
  }
});
```

**What it does:** Logs tool errors to `.remember/logs/hook-errors.log` for later debugging. Fails silently to avoid infinite error loops.

#### D. Hooks README

Create `.claude/hooks/README.md` to document the hook lifecycle and how to add new hooks. This is especially useful when the team grows or when returning to the project after a break.

